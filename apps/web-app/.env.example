# WibeStyle web-app environment example.
# Copy to apps/web-app/.env.local for local development.

# Public API URL used by browser code and Next rewrites.
# Local backend:
NEXT_PUBLIC_API_URL=http://localhost:8080

# Public URL of this web application.
# Used for media/share links and OAuth-related redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Public landing URL.
# Used for public gallery/share SEO links back to the marketing site.
NEXT_PUBLIC_LANDING_URL=http://localhost:3000

# Production example:
# NEXT_PUBLIC_API_URL=https://api.wibestyle.ru
# NEXT_PUBLIC_APP_URL=https://app.wibestyle.ru
# NEXT_PUBLIC_LANDING_URL=https://wibestyle.ru
