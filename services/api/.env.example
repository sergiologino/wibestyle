# WibeStyle API / Backend environment example.
# Copy to services/api/.env for local shell usage, or copy values into
# IntelliJ IDEA Run Configuration / server environment.
#
# Important: Spring Boot does not automatically load this file by itself.
# PowerShell local run examples are in docs/LOCAL_RUN_AND_DEPLOY.md.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
SERVER_PORT=8080

# -----------------------------------------------------------------------------
# PostgreSQL
# Local docker-compose database:
#   jdbc:postgresql://localhost:5432/wibestyle
# If API runs inside Docker Compose network, use:
#   jdbc:postgresql://postgres:5432/wibestyle
# -----------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/wibestyle
SPRING_DATASOURCE_USERNAME=wibestyle
SPRING_DATASOURCE_PASSWORD=wibestyle

# -----------------------------------------------------------------------------
# Redis
# Current default auth refresh-token store is JDBC, so Redis is optional.
# Use Redis later if wibestyle.auth.refresh-token-store is changed to redis.
# -----------------------------------------------------------------------------
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Auth / JWT
# Must be at least 32 bytes. In production generate a strong random secret and
# keep it stable; changing it invalidates active access tokens.
# -----------------------------------------------------------------------------
WIBESTYLE_JWT_SECRET=dev-jwt-secret-change-me-in-production-min-32-chars

# -----------------------------------------------------------------------------
# Admin
# X-Admin-Key for admin API calls and initial admin password.
# Local defaults:
#   admin@wibestyle.local / dev-admin-password
# -----------------------------------------------------------------------------
WIBESTYLE_ADMIN_API_KEY=dev-admin-key
WIBESTYLE_ADMIN_BOOTSTRAP_PASSWORD=dev-admin-password

# -----------------------------------------------------------------------------
# Email OTP
# Local default logs email codes instead of sending real mail.
# For real SMTP: set WIBESTYLE_MAIL_ENABLED=true and DEV_LOG_ONLY=false.
# -----------------------------------------------------------------------------
WIBESTYLE_MAIL_ENABLED=false
WIBESTYLE_MAIL_FROM=noreply@wibestyle.ru
WIBESTYLE_MAIL_DEV_LOG_ONLY=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false

# -----------------------------------------------------------------------------
# SMS OTP
# Empty SMS.ru API ID means local/dev phone OTP code is 0000.
# -----------------------------------------------------------------------------
WIBESTYLE_SMS_RU_API_ID=

# -----------------------------------------------------------------------------
# Geo / OAuth visibility
# Used to hide Google OAuth for RU traffic when proxy/CDN does not pass country.
# -----------------------------------------------------------------------------
WIBESTYLE_GEOIP_DEFAULT_COUNTRY=

# -----------------------------------------------------------------------------
# OAuth providers
# Provider redirect URI in OAuth cabinet should point to backend callback:
#   http://localhost:8080/api/v1/auth/oauth/{provider}/callback
#   https://api.example.com/api/v1/auth/oauth/{provider}/callback
# The return URLs below are app destinations after backend finishes OAuth.
# -----------------------------------------------------------------------------
WIBESTYLE_OAUTH_API_PUBLIC_BASE=http://localhost:8080
WIBESTYLE_OAUTH_WEB_CALLBACK=http://localhost:3001/auth/oauth/callback
WIBESTYLE_OAUTH_MOBILE_CALLBACK=wibestyle://auth/oauth/callback

WIBESTYLE_OAUTH_YANDEX_ENABLED=false
WIBESTYLE_OAUTH_YANDEX_CLIENT_ID=
WIBESTYLE_OAUTH_YANDEX_CLIENT_SECRET=

WIBESTYLE_OAUTH_GOOGLE_ENABLED=false
WIBESTYLE_OAUTH_GOOGLE_CLIENT_ID=
WIBESTYLE_OAUTH_GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Billing
# Local: mock provider and dev subscribe shortcut.
# Production: set provider=yookassa and subscribe-dev-enabled=false.
# -----------------------------------------------------------------------------
WIBESTYLE_BILLING_PROVIDER=mock
WIBESTYLE_BILLING_SUBSCRIBE_DEV_ENABLED=true
WIBESTYLE_BILLING_RETURN_URL=http://localhost:3001/paywall/return
WIBESTYLE_YOOKASSA_SHOP_ID=
WIBESTYLE_YOOKASSA_SECRET_KEY=
WIBESTYLE_YOOKASSA_API_BASE=https://api.yookassa.ru

# -----------------------------------------------------------------------------
# Media storage
# local backend stores avatar / try-on files on disk.
# Leave root empty locally to auto-detect repo data/storage; on server set a
# mounted persistent path such as /data/wibestyle-media.
# -----------------------------------------------------------------------------
WIBESTYLE_STORAGE_BACKEND=local
WIBESTYLE_STORAGE_ROOT=

# -----------------------------------------------------------------------------
# AI / noteapp-ai-integration
# Local default disables real AI generation. Enable only after noteapp and keys
# are configured.
# -----------------------------------------------------------------------------
WIBESTYLE_AI_ENABLED=false
WIBESTYLE_AI_BASE_URL=http://localhost:8091
WIBESTYLE_AI_API_KEY=
WIBESTYLE_AI_FALLBACK_TO_DEMO=false
WIBESTYLE_AI_ASYNC_ENABLED=true
WIBESTYLE_AI_TIMEOUT_SECONDS=180
WIBESTYLE_AI_TRYON_NETWORK=wibestyle-vton
WIBESTYLE_AI_SEASON_VIDEO_NETWORK=wibestyle-season-video
WIBESTYLE_AI_SIZE_COMPLIMENT_NETWORK=gpt-4o-mini
WIBESTYLE_AI_WEBHOOK_SECRET=
