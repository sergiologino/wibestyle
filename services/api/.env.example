# noteapp-ai-integration
WIBESTYLE_AI_ENABLED=false
WIBESTYLE_AI_BASE_URL=http://localhost:8091
WIBESTYLE_AI_API_KEY=
WIBESTYLE_AI_TRYON_NETWORK=wibestyle-vton
WIBESTYLE_AI_SIZE_COMPLIMENT_NETWORK=gpt-4o-mini
WIBESTYLE_AI_SEASON_VIDEO_NETWORK=
WIBESTYLE_AI_FALLBACK_TO_DEMO=false

# SMS Aero API v2. Leave email/api key empty in dev to use OTP code 0000 in logs.
WIBESTYLE_SMS_AERO_EMAIL=
WIBESTYLE_SMS_AERO_API_KEY=
WIBESTYLE_SMS_AERO_SIGN="SMS Aero"
WIBESTYLE_SMS_AERO_CHANNEL=DIRECT
WIBESTYLE_SMS_AERO_BASE_URL=https://gate.smsaero.ru/v2

# Reserved for Telegram outbound integration through noteapp-ai-integration.
WIBESTYLE_TELEGRAM_CHANNEL_URL=
WIBESTYLE_TELEGRAM_CHANNEL_NAME=Telegram
WIBESTYLE_TELEGRAM_CHANNEL_ID=
WIBESTYLE_TELEGRAM_TOPIC_ID=

# Billing / YooKassa recurring payments.
WIBESTYLE_BILLING_PROVIDER=mock
WIBESTYLE_BILLING_SUBSCRIBE_DEV_ENABLED=true
WIBESTYLE_BILLING_RETURN_URL=http://localhost:3001/paywall/return
WIBESTYLE_BILLING_MOBILE_RETURN_URL=wibestyle://paywall/return
WIBESTYLE_YOOKASSA_SHOP_ID=
WIBESTYLE_YOOKASSA_SECRET_KEY=

# Expo Push Service. Access token is only required with enhanced push security.
WIBESTYLE_PUSH_ENABLED=true
WIBESTYLE_EXPO_PUSH_ACCESS_TOKEN=
